# --- Frontend env — copy to .env.local. Safe to be public by design. ---

# URL of the agent/contact backend (the Lambda Function URL or local server).
# NOTE: NEXT_PUBLIC_* values are shipped to the browser, so ONLY non-secret
# values go here. This is just an address, not a key.
#   Local backend:  http://localhost:3001
#   Production:      https://<your-lambda-function-url>
NEXT_PUBLIC_AGENT_URL=http://localhost:3001

# Leave NEXT_PUBLIC_AGENT_URL unset to run the chat in built-in demo mode
# (no backend, no key needed).

# NEVER put the OpenAI key here. Secret keys live ONLY in backend/.env.
